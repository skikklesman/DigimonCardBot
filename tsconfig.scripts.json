{
  // Deploy-time scripts run under Node (≥22.18 native TS), not workerd —
  // they get Node types here so Worker code (base tsconfig) can't
  // accidentally use Node globals. `npm run typecheck` checks both.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // workers-types too: scripts/source-contract.ts imports src/sync
    // modules whose signatures mention D1Database.
    "types": ["node", "@cloudflare/workers-types"],
    // Node's ESM loader requires explicit .ts extensions on relative imports.
    "allowImportingTsExtensions": true
  },
  "include": ["scripts/**/*.ts"]
}
